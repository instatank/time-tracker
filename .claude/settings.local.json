{
  "permissions": {
    "allow": [
      "Bash(git init)",
      "Bash(git add tracker.html)",
      "Bash(git commit:*)",
      "Bash(git remote add origin https://github.com/instatank/time-tracker.git)",
      "Bash(git branch -M main)",
      "Bash(git push -u origin main)",
      "Bash(ssh -T git@github.com -o StrictHostKeyChecking=no)",
      "Bash(git remote set-url origin git@github.com:instatank/time-tracker.git)",
      "Bash(npm install -g vercel)",
      "Bash(sudo npm install -g vercel)",
      "Bash(npm install -g vercel --prefix ~/.npm-global)",
      "Bash(echo \"PATH: $HOME/.npm-global/bin\")",
      "Bash(~/.npm-global/bin/vercel --version)",
      "Bash(~/.npm-global/bin/vercel deploy --prod --yes)",
      "Bash(~/.npm-global/bin/vercel deploy --prod --yes --name time-tracker)"
    ]
  }
}
